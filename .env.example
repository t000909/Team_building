# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Mail Server Configuration (Optional - fallback to console logs if unset)
# Configure these variables to enable real email forwarding from the contact form
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=

# Verified Sender Address: Required for services like SendGrid, Mailgun, Amazon SES, etc.
# This must be an email address verified on your sending domain (e.g. no-reply@teambuilding.biz)
SENDER_EMAIL=

# --- GOOGLE SHEETS & EMAIL AUTOMATION CONFIGURATION ---
# To save submissions to Google Sheets and send email directly without any third party SMTP servers,
# configure a Google Sheets Apps Script Web App (instructions in the chat response) and set the URL here:
GOOGLE_SHEETS_WEBAPP_URL=

# --- SENDGRID CONFIGURATION QUICK GUIDE ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx (Your SendGrid API Key)
# SMTP_SECURE=false
# SENDER_EMAIL=no-reply@teambuilding.biz (Your verified sender email in SendGrid)
